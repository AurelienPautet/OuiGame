{
  "name": "wiigamebien",
  "version": "1.0.0",
  "description": "",
  "main": "Server/server.js",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "24.x",
    "npm": "11.x"
  },
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev:tailwind": "npx tailwindcss -i Public/src/css/styles.css -o Public/src/css/tails.css --watch",
    "dev": "nodemon Server/server.js",
    "start": "npm run build && node Server/server.js",
    "build": "cd Client && npm install --include=dev && npm run build",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-data": "node Server/db/migrate_data.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "{Server,shared}/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "Client/**/*.{js,jsx,css,html}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.1",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.1.0",
    "pg": "^8.13.1",
    "socket-types": "^1.0.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.12.0",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.13"
  }
}
