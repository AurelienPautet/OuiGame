{
  "name": "@ouigame/root",
  "version": "1.0.0",
  "description": "",
  "private": true,
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "24.x"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "picomatch@<2.3.2": "^2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4",
      "flatted@<3.4.2": "^3.4.2",
      "socket.io-parser@>=4.0.0 <4.2.6": "^4.2.6",
      "path-to-regexp@<0.1.13": "^0.1.13",
      "ws@>=8.0.0 <8.20.1": "^8.20.1"
    }
  },
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "pnpm --filter @ouigame/api dev",
    "dev:web": "pnpm --filter @ouigame/web dev",
    "build": "turbo run build",
    "start": "node apps/api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint . && pnpm --filter @ouigame/web lint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate-data": "node apps/api/db/migrate_data.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "{apps/api,shared}/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "apps/web/**/*.{js,jsx,css,html}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.12.0",
    "globals": "^15.11.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.5",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "turbo": "^2.5.0"
  }
}
