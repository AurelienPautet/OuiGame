# Build-time config for the itch.io static bundle (`pnpm --filter @ouigame/web
# build:itch`, i.e. `vite build --mode itch`). These are PUBLIC URLs, not
# secrets — the itch build runs cross-origin and talks to the hosted backend
# (CORS for the itch origins is already allowed server-side). Auth is a bearer
# token in localStorage, which works cross-origin.
VITE_API_URL=https://wiitank.pautet.net/api
VITE_SOCKET_URL=https://wiitank.pautet.net
