{
  "extends": "@ouigame/config-ts/tsconfig.base.json",
  // Inherit module:esnext + moduleResolution:bundler from the base. This is
  // load-bearing: it lets @ouigame/shared/{api,socket} resolve to their .ts
  // types (under nodenext the api would resolve to the typeless dist/*.cjs and
  // the shared source's extensionless imports would error). The runtime is tsx,
  // which has its own resolver — verified to load the CJS @ouigame/db + the
  // ESM game from .ts.
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"]
  },
  // All source is .ts now. __tests__ run via jest (@swc transpile) — their types
  // aren't the gate, so they're excluded from this strict typecheck.
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**"]
}
