# Copy this file to `.env` and fill in any blanks.
# The defaults below match the local Docker Postgres dev setup (see
# database_setup.txt). `.env` itself is gitignored — never commit real secrets.

# Express / Socket.IO backend port (Vite dev client runs separately on :5173)
PORT=8000

# Postgres — local dev runs in Docker on host port 5433
DB_HOST=localhost
DB_PORT=5433
DB_USER=ouigame
DB_PASSWORD=ouigame
DB_NAME=ouigame

# Google OAuth client ID — from Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
