# Auto-install dependencies when pnpm-lock.yaml changes on a branch checkout (QoL).
# Args: $1 previous HEAD, $2 new HEAD, $3 = 1 for a branch checkout (0 for a file checkout).
[ "$3" = "1" ] || exit 0
# Skip silently when the previous ref isn't a real commit
# (initial checkout / `git worktree add` pass an all-zero SHA).
git rev-parse --verify --quiet "$1^{commit}" >/dev/null || exit 0
if ! git diff --quiet "$1" "$2" -- pnpm-lock.yaml; then
	echo "husky - pnpm-lock.yaml changed, running pnpm install..."
	pnpm install --frozen-lockfile
fi
