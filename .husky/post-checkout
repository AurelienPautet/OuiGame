# Auto-install dependencies when pnpm-lock.yaml changes on a branch checkout (QoL).
# Args: $1 previous HEAD, $2 new HEAD, $3 = 1 for a branch checkout (0 for a file checkout).
[ "$3" = "1" ] || exit 0
if git diff-tree -r --name-only "$1" "$2" | grep -q '^pnpm-lock\.yaml$'; then
	echo "husky - pnpm-lock.yaml changed, running pnpm install..."
	pnpm install --frozen-lockfile
fi
