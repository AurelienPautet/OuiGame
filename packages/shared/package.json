{
  "name": "@ouigame/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared contracts (types, socket events, Zod API schemas) and the isomorphic game runtime for OuiGame.",
  "sideEffects": false,
  "exports": {
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    },
    "./socket": {
      "types": "./src/socket/index.ts",
      "import": "./src/socket/index.ts"
    },
    "./api": {
      "import": "./src/api/index.ts",
      "require": "./dist/api.cjs"
    },
    "./game": {
      "import": "./dist/game.js",
      "require": "./dist/game.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ouigame/config-ts": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3"
  }
}
