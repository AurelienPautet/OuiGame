{
  "compilerOptions": {
    "strict": true,
    // Phase 5 strictness ratchet: index access yields T | undefined (forces
    // guarding array/record lookups), and optional props can't be assigned
    // `undefined` explicitly (distinguishes "absent" from "present-but-undefined").
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true
  }
}
